# Auth.js Authentication Secrets
# AUTH_SECRET can be any random long string (e.g. run `npx auth secret` to generate)
AUTH_SECRET="your_random_secret_here"
AUTH_URL="http://localhost:4321"
AUTH_TRUST_HOST=true

# GitHub OAuth (Settings -> Developer settings -> OAuth Apps)
GITHUB_CLIENT_ID="your_github_id_here"
GITHUB_CLIENT_SECRET="your_github_secret_here"

# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID="your_google_id_here"
GOOGLE_CLIENT_SECRET="your_google_secret_here"
