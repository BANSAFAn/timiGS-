---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import MusicApp from '../../components/react-pages/MusicApp';
import { useTranslations } from '../../i18n/utils';
import { Language } from '../../i18n/types';
import { getSession } from 'auth-astro/server';

const { lang } = Astro.params;

const isValidLang = Object.values(Language).includes(lang as Language);
if (!lang || !isValidLang) {
  return Astro.redirect('/en/music');
}

const t = useTranslations(lang as Language);
const session = await getSession(Astro.request);
---

<Layout title="Music | TimiGS">
  <MusicApp client:load lang={lang as Language} t={t} session={session} />
</Layout>
