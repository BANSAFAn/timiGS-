{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimiGS",
  "version": "1.2.0",
  "identifier": "com.timigs.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimiGS - Activity Tracker",
        "url": "/",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "tray",
        "title": "TimiGS Tray",
        "url": "/tray",
        "width": 240,
        "height": 220,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data: https://www.google.com https://t0.gstatic.com https://t1.gstatic.com https://t2.gstatic.com; media-src 'self' asset: https://asset.localhost blob: data: file:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:* https://asset.localhost blob: data: file: https://geocoding-api.open-meteo.com https://api.open-meteo.com https://nominatim.open-meteo.com https://nominatim.openstreetmap.org http://ip-api.com https://www.google.com; fs:allow-read-recursive: true; fs:allow-write: false"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "deb",
      "rpm",
      "appimage",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "Ukrainian",
          "German",
          "French",
          "SimpChinese",
          "Arabic"
        ],
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installerHooks": "windows/hooks.nsh",
        "startMenuFolder": "TimiGS",
        "compression": "lzma"
      }
    },
    "resources": [
      "../public/music"
    ],
    "shortDescription": "Track your PC activity",
    "longDescription": "TimiGS is a lightweight activity tracker that monitors which programs you use and provides detailed analytics about your computer usage.",
    "copyright": "© 2024 TimiGS",
    "category": "Utility",
    "publisher": "Baneronetwo"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBGREMyQzIyQ0IwQTJEOEUKUldTT0xRckxJaXpjRHcrNnltak5wM0NIWGRBMHppU0JMdzY2eUlNNnpMS08xQ2JObVdqd05qY0UK",
      "endpoints": [
        "https://github.com/BANSAFAn/timiGS-/releases/latest/download/latest.json"
      ]
    },
    "cli": {
      "description": "TimiGS Activity Tracker CLI",
      "args": [
        {
          "name": "minimized",
          "short": "m",
          "description": "Start the application minimized to tray"
        },
        {
          "name": "help",
          "short": "h",
          "description": "Show help information"
        },
        {
          "name": "version",
          "short": "v",
          "description": "Show version information"
        }
      ]
    }
  }
}
